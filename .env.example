# Cola aqui a connection string da Neon (com -pooler no host).
# Cria a base de dados em neon.tech, botão "Connect", copia a "Pooled connection".
DATABASE_URL=

# Segredo para os hashes de verificação dos bilhetes.
# Gera com:  openssl rand -hex 32
HASH_SECRET=

# UUID da conta que pode disparar o sorteio (preenche mais tarde).
ADMIN_SORTEIO_ID=
